---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.pubDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<Layout title={`${entry.data.title ?? entry.id.split('/').pop().replace(/\.mdoc$|\.md$/, '')} | Stage Blog`} description={entry.data.description}>

  <!-- ══════════════════════════════════════════════════════
       ARTICLE HERO — split layout (text left, image right)
       ══════════════════════════════════════════════════════ -->
  <section class="article-hero">
    <div class="article-hero-inner">
      <div class="article-hero-text">
        {entry.data.category && (
          <a href="/blog" class="article-category-link">{entry.data.category}</a>
        )}

        <h1 class="article-title">{entry.data.title ?? entry.id.split('/').pop().replace(/\.mdoc$|\.md$/, '')}</h1>

        <div class="article-author-row">
          <div class="article-author-avatar">
            {entry.data.author?.charAt(0) || 'S'}
          </div>
          <div class="article-author-details">
            <span class="article-author-name">{entry.data.author || 'Stage'}</span>
            <div class="article-author-meta">
              <time datetime={entry.data.pubDate.toISOString()}>{formattedDate}</time>
              {entry.data.readTime && (
                <>
                  <span class="article-meta-dot">·</span>
                  <span>{entry.data.readTime}</span>
                </>
              )}
            </div>
          </div>
        </div>
      </div>

      {entry.data.image && (
        <div class="article-hero-image-wrapper">
          <img
            src={entry.data.image}
            alt={entry.data.title ?? entry.id.split('/').pop().replace(/\.mdoc$|\.md$/, '')} 
            class="article-hero-image"
            loading="eager"
          />
        </div>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       DIVIDER
       ══════════════════════════════════════════════════════ -->
  <div class="article-divider"></div>

  <!-- ══════════════════════════════════════════════════════
       ARTICLE BODY
       ══════════════════════════════════════════════════════ -->
  <main class="article-main">
    <div class="article-layout">

      <!-- Content column -->
      <article class="article-content">
        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="article-sidebar">
        <div class="article-sidebar-cta">
          <h3 class="article-sidebar-cta-title">Comece a usar o Stage hoje</h3>
          <ul class="article-sidebar-cta-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#3b5bdb" opacity="0.15"/><path d="M5 8l2 2 4-4" stroke="#3b5bdb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Gerencie sua agenda de eventos
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#3b5bdb" opacity="0.15"/><path d="M5 8l2 2 4-4" stroke="#3b5bdb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Controle financeiro completo
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#3b5bdb" opacity="0.15"/><path d="M5 8l2 2 4-4" stroke="#3b5bdb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Teste grátis por 7 dias
            </li>
          </ul>
          <a href="https://v1.stagesystem.com.br/criar-conta" target="_blank" rel="noopener noreferrer" class="article-sidebar-cta-btn">
            Comece Grátis
          </a>
        </div>
      </aside>
    </div>
  </main>

  <!-- ══════════════════════════════════════════════════════
       BACK TO BLOG
       ══════════════════════════════════════════════════════ -->
  <div class="article-back-section">
    <div class="article-back-inner">
      <a href="/blog" class="article-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"></path><polyline points="12 19 5 12 12 5"></polyline></svg>
        Voltar para o blog
      </a>
    </div>
  </div>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     ARTICLE HERO
     ═══════════════════════════════════════════════════════ */
  .article-hero {
    padding-top: 80px;
    background: linear-gradient(165deg, #f8faff 0%, #eef2ff 40%, #f0f4ff 100%);
  }

  .article-hero-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 64px 24px 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .article-hero-text {
    display: flex;
    flex-direction: column;
  }

  .article-category-link {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: #6366f1;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.2s;
  }

  .article-category-link:hover {
    color: #3b5bdb;
  }

  .article-title {
    font-family: var(--font-inter), sans-serif;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: #0f1117;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 32px;
  }

  .article-author-row {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .article-author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b5bdb 0%, #6366f1 100%);
    color: #ffffff;
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .article-author-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .article-author-name {
    font-size: 15px;
    font-weight: 700;
    color: #0f1117;
  }

  .article-author-meta {
    font-size: 13px;
    color: #94a3b8;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .article-meta-dot {
    font-size: 16px;
    line-height: 1;
  }

  .article-hero-image-wrapper {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(15, 17, 23, 0.08);
    aspect-ratio: 4 / 3;
  }

  .article-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }


  /* ═══════════════════════════════════════════════════════
     DIVIDER
     ═══════════════════════════════════════════════════════ */
  .article-divider {
    max-width: 1140px;
    margin: 0 auto;
    border-bottom: 1px solid #e8eaf0;
  }


  /* ═══════════════════════════════════════════════════════
     ARTICLE BODY LAYOUT (content + sidebar)
     ═══════════════════════════════════════════════════════ */
  .article-main {
    background: #ffffff;
    padding: 56px 0 80px;
  }

  .article-layout {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 64px;
    align-items: start;
  }


  /* ═══════════════════════════════════════════════════════
     ARTICLE CONTENT — typography
     ═══════════════════════════════════════════════════════ */
  .article-content {
    max-width: 100%;
    font-family: var(--font-inter), sans-serif;
  }

  /* Paragraphs */
  .article-content :global(p) {
    font-size: 1.1rem;
    line-height: 1.85;
    color: #334155;
    margin-bottom: 1.75rem;
  }

  /* Headings */
  .article-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 800;
    color: #0f1117;
    line-height: 1.3;
    letter-spacing: -0.02em;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.6rem;
    border-bottom: 2px solid #f1f5f9;
  }

  .article-content :global(h3) {
    font-size: 1.3rem;
    font-weight: 700;
    color: #0f1117;
    line-height: 1.35;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .article-content :global(h4) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e293b;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  /* Links */
  .article-content :global(a) {
    color: #3b5bdb;
    text-decoration: underline;
    text-decoration-color: rgba(59, 91, 219, 0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }

  .article-content :global(a:hover) {
    text-decoration-color: #3b5bdb;
  }

  /* Lists */
  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.75rem;
  }

  .article-content :global(li) {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #334155;
    margin-bottom: 0.5rem;
  }

  .article-content :global(li::marker) {
    color: #3b5bdb;
  }

  /* Blockquotes */
  .article-content :global(blockquote) {
    border-left: 4px solid #3b5bdb;
    background: #f8faff;
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    border-radius: 0 12px 12px 0;
  }

  .article-content :global(blockquote p) {
    color: #475569;
    font-style: italic;
    margin-bottom: 0;
  }

  /* Code */
  .article-content :global(code) {
    background: #f1f5f9;
    color: #0f172a;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .article-content :global(pre) {
    background: #0f172a;
    color: #e2e8f0;
    padding: 1.5rem;
    border-radius: 12px;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .article-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  /* Images inside article */
  .article-content :global(img) {
    width: 100%;
    border-radius: 12px;
    margin: 2rem 0;
    box-shadow: 0 4px 16px rgba(15, 17, 23, 0.06);
  }

  /* Strong / Bold */
  .article-content :global(strong) {
    color: #0f1117;
    font-weight: 700;
  }

  /* Horizontal rule */
  .article-content :global(hr) {
    border: none;
    border-top: 1px solid #e8eaf0;
    margin: 3rem 0;
  }


  /* ═══════════════════════════════════════════════════════
     SIDEBAR
     ═══════════════════════════════════════════════════════ */
  .article-sidebar {
    position: sticky;
    top: 104px;
  }

  .article-sidebar-cta {
    background: #0f172a;
    border-radius: 16px;
    padding: 32px 28px;
    color: #ffffff;
  }

  .article-sidebar-cta-title {
    font-family: var(--font-inter), sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 20px;
    line-height: 1.3;
  }

  .article-sidebar-cta-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .article-sidebar-cta-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: #cbd5e1;
    line-height: 1.5;
  }

  .article-sidebar-cta-list li svg {
    flex-shrink: 0;
  }

  .article-sidebar-cta-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px 24px;
    border-radius: 12px;
    background: linear-gradient(135deg, #60A5FA 0%, #3b5bdb 100%);
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .article-sidebar-cta-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }


  /* ═══════════════════════════════════════════════════════
     BACK TO BLOG
     ═══════════════════════════════════════════════════════ */
  .article-back-section {
    background: #ffffff;
    border-top: 1px solid #e8eaf0;
  }

  .article-back-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 28px 24px;
  }

  .article-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #3b5bdb;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: gap 0.25s ease, color 0.2s;
  }

  .article-back-link:hover {
    gap: 12px;
    color: #2a47b8;
  }


  /* ═══════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .article-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .article-sidebar {
      position: static;
      max-width: 400px;
    }
  }

  @media (max-width: 768px) {
    .article-hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 48px 20px 40px;
    }

    .article-title {
      font-size: 1.65rem;
    }

    .article-hero-image-wrapper {
      aspect-ratio: 16 / 10;
    }

    .article-content :global(p) {
      font-size: 1rem;
      line-height: 1.8;
    }

    .article-content :global(h2) {
      font-size: 1.35rem;
      margin-top: 2.5rem;
    }

    .article-content :global(h3) {
      font-size: 1.15rem;
    }
  }

  @media (max-width: 480px) {
    .article-hero-inner {
      padding: 36px 16px 32px;
    }

    .article-layout {
      padding: 0 16px;
    }

    .article-sidebar-cta {
      padding: 24px 20px;
    }
  }
</style>
