---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts[0];
const remainingPosts = posts.slice(1);
---

<Layout title="Blog | Stage" description="Artigos, dicas e estratégias para profissionais que vivem de eventos.">
  <!-- Hero Section -->
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <div class="blog-hero-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
        Blog Stage
      </div>

      <h1 class="blog-hero-title">
        Conteúdo para quem quer<br />
        <span class="blog-hero-highlight">lucrar mais</span> com eventos
      </h1>

      <p class="blog-hero-subtitle">
        Dicas práticas, estratégias e tendências para transformar seu negócio de eventos em uma máquina de resultados.
      </p>

      <div class="blog-search-wrapper">
        <div class="blog-search-container">
          <svg class="blog-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
          <input 
            type="text" 
            placeholder="Buscar artigos sobre gestão, finanças, contratos..." 
            class="blog-search-input"
            id="blog-search"
          />
        </div>
      </div>
    </div>
  </section>

  <main class="blog-main">
    <div class="blog-container">

      <!-- Featured Post -->
      {featuredPost && (
        <section class="blog-featured-section">
          <div class="blog-section-label">
            <div class="blog-section-label-line"></div>
            <span>Destaque</span>
            <div class="blog-section-label-line"></div>
          </div>

          <a href={`/blog/${featuredPost.slug}`} class="blog-featured-card">
            <div class="blog-featured-image-wrapper">
              {featuredPost.data.image ? (
                <img 
                  src={featuredPost.data.image} 
                  alt={featuredPost.data.title} 
                  class="blog-featured-image" 
                  loading="eager"
                />
              ) : (
                <div class="blog-featured-image-placeholder">
                  <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                </div>
              )}
            </div>
            <div class="blog-featured-content">
              {featuredPost.data.category && (
                <span class="blog-card-category">{featuredPost.data.category}</span>
              )}
              <h2 class="blog-featured-title">{featuredPost.data.title}</h2>
              <p class="blog-featured-description">{featuredPost.data.description}</p>
              <div class="blog-card-meta">
                <div class="blog-card-author-info">
                  <div class="blog-card-author-avatar">
                    {featuredPost.data.author?.charAt(0) || 'S'}
                  </div>
                  <span class="blog-card-author-name">{featuredPost.data.author || 'Stage'}</span>
                </div>
                <div class="blog-card-meta-right">
                  {featuredPost.data.readTime && (
                    <span class="blog-card-read-time">{featuredPost.data.readTime}</span>
                  )}
                </div>
              </div>
            </div>
          </a>
        </section>
      )}

      <!-- All Posts Grid -->
      <section class="blog-grid-section">
        <div class="blog-section-label">
          <div class="blog-section-label-line"></div>
          <span>Todos os artigos</span>
          <div class="blog-section-label-line"></div>
        </div>

        <div class="blog-grid">
          {remainingPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="blog-card">
              <div class="blog-card-image-wrapper">
                {post.data.image ? (
                  <img 
                    src={post.data.image} 
                    alt={post.data.title} 
                    class="blog-card-image" 
                    loading="lazy"
                  />
                ) : (
                  <div class="blog-card-image-placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                      <circle cx="8.5" cy="8.5" r="1.5"></circle>
                      <polyline points="21 15 16 10 5 21"></polyline>
                    </svg>
                  </div>
                )}
              </div>
              <div class="blog-card-body">
                {post.data.category && (
                  <span class="blog-card-category">{post.data.category}</span>
                )}
                <h3 class="blog-card-title">{post.data.title}</h3>
                <p class="blog-card-description">{post.data.description}</p>
                <div class="blog-card-meta">
                  <div class="blog-card-author-info">
                    <div class="blog-card-author-avatar">
                      {post.data.author?.charAt(0) || 'S'}
                    </div>
                    <span class="blog-card-author-name">{post.data.author || 'Stage'}</span>
                  </div>
                  <div class="blog-card-meta-right">
                    {post.data.readTime && (
                      <span class="blog-card-read-time">{post.data.readTime}</span>
                    )}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     HERO SECTION
     ═══════════════════════════════════════════════════════ */
  .blog-hero {
    padding-top: 80px;
    background: linear-gradient(165deg, #f8faff 0%, #eef2ff 40%, #f0f4ff 100%);
    position: relative;
    overflow: hidden;
  }

  .blog-hero::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(59, 91, 219, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .blog-hero::after {
    content: '';
    position: absolute;
    bottom: -100px;
    left: -150px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .blog-hero-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 80px 24px 72px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .blog-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 9999px;
    background: rgba(59, 91, 219, 0.08);
    border: 1px solid rgba(59, 91, 219, 0.15);
    color: #3b5bdb;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.03em;
    margin-bottom: 28px;
  }

  .blog-hero-title {
    font-family: var(--font-inter), sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 800;
    color: #0f1117;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .blog-hero-highlight {
    background: linear-gradient(135deg, #3b5bdb 0%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .blog-hero-subtitle {
    font-size: 1.15rem;
    color: #5a6278;
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 36px;
  }

  .blog-search-wrapper {
    max-width: 540px;
    margin: 0 auto;
  }

  .blog-search-container {
    position: relative;
    display: flex;
    align-items: center;
  }

  .blog-search-icon {
    position: absolute;
    left: 20px;
    pointer-events: none;
    z-index: 2;
  }

  .blog-search-input {
    width: 100%;
    padding: 16px 24px 16px 52px;
    border-radius: 16px;
    border: 1.5px solid #e2e8f0;
    background: #ffffff;
    font-size: 15px;
    font-family: var(--font-inter), sans-serif;
    color: #0f1117;
    outline: none;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(15, 17, 23, 0.04), 0 1px 3px rgba(15, 17, 23, 0.03);
  }

  .blog-search-input::placeholder {
    color: #94a3b8;
  }

  .blog-search-input:focus {
    border-color: #3b5bdb;
    box-shadow: 0 4px 20px rgba(59, 91, 219, 0.1), 0 0 0 4px rgba(59, 91, 219, 0.06);
  }


  /* ═══════════════════════════════════════════════════════
     MAIN CONTENT
     ═══════════════════════════════════════════════════════ */
  .blog-main {
    background: #ffffff;
    padding-bottom: 100px;
  }

  .blog-container {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
  }


  /* ═══════════════════════════════════════════════════════
     SECTION LABELS
     ═══════════════════════════════════════════════════════ */
  .blog-section-label {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 36px;
    padding-top: 56px;
  }

  .blog-section-label span {
    font-size: 13px;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .blog-section-label-line {
    flex: 1;
    height: 1px;
    background: #e8eaf0;
  }


  /* ═══════════════════════════════════════════════════════
     FEATURED CARD
     ═══════════════════════════════════════════════════════ */
  .blog-featured-card {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 0;
    background: #ffffff;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid #e8eaf0;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 1px 3px rgba(15, 17, 23, 0.04);
  }

  .blog-featured-card:hover {
    box-shadow: 0 20px 60px rgba(15, 17, 23, 0.08), 0 4px 16px rgba(15, 17, 23, 0.04);
    transform: translateY(-4px);
    border-color: #d4d9e6;
  }

  .blog-featured-image-wrapper {
    position: relative;
    overflow: hidden;
    min-height: 340px;
  }

  .blog-featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .blog-featured-card:hover .blog-featured-image {
    transform: scale(1.05);
  }

  .blog-featured-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 340px;
    background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-featured-content {
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .blog-featured-title {
    font-family: var(--font-inter), sans-serif;
    font-size: 1.65rem;
    font-weight: 800;
    color: #0f1117;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
    transition: color 0.25s ease;
  }

  .blog-featured-card:hover .blog-featured-title {
    color: #3b5bdb;
  }

  .blog-featured-description {
    font-size: 0.95rem;
    color: #64748b;
    line-height: 1.7;
    margin-bottom: 24px;
  }


  /* ═══════════════════════════════════════════════════════
     CARD CATEGORY TAG
     ═══════════════════════════════════════════════════════ */
  .blog-card-category {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    color: #6366f1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }


  /* ═══════════════════════════════════════════════════════
     CARD META (author + read time)
     ═══════════════════════════════════════════════════════ */
  .blog-card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid #f1f5f9;
  }

  .blog-card-author-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .blog-card-author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, #3b5bdb 0%, #6366f1 100%);
    color: #ffffff;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .blog-card-author-name {
    font-size: 13px;
    font-weight: 600;
    color: #334155;
  }

  .blog-card-read-time {
    font-size: 12px;
    color: #94a3b8;
    font-weight: 500;
  }


  /* ═══════════════════════════════════════════════════════
     POST CARDS GRID
     ═══════════════════════════════════════════════════════ */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #e8eaf0;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 1px 3px rgba(15, 17, 23, 0.04);
  }

  .blog-card:hover {
    box-shadow: 0 16px 48px rgba(15, 17, 23, 0.08), 0 4px 12px rgba(15, 17, 23, 0.04);
    transform: translateY(-6px);
    border-color: #d4d9e6;
  }

  .blog-card-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #f8fafc;
  }

  .blog-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .blog-card:hover .blog-card-image {
    transform: scale(1.06);
  }

  .blog-card-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .blog-card-title {
    font-family: var(--font-inter), sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f1117;
    line-height: 1.35;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
    transition: color 0.25s ease;
  }

  .blog-card:hover .blog-card-title {
    color: #3b5bdb;
  }

  .blog-card-description {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.65;
    margin-bottom: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }


  /* ═══════════════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .blog-hero-inner {
      padding: 60px 20px 56px;
    }

    .blog-hero-title {
      font-size: 2rem;
    }

    .blog-hero-subtitle {
      font-size: 1rem;
    }

    .blog-featured-card {
      grid-template-columns: 1fr;
    }

    .blog-featured-image-wrapper {
      min-height: 220px;
    }

    .blog-featured-content {
      padding: 28px 24px;
    }

    .blog-featured-title {
      font-size: 1.35rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .blog-card-body {
      padding: 20px;
    }
  }

  @media (max-width: 480px) {
    .blog-container {
      padding: 0 16px;
    }

    .blog-hero-inner {
      padding: 48px 16px 40px;
    }

    .blog-search-input {
      padding: 14px 20px 14px 46px;
      font-size: 14px;
    }

    .blog-featured-content {
      padding: 20px 16px;
    }

    .blog-card-body {
      padding: 16px;
    }
  }
</style>
