---
import '../styles/globals.css';
import { Header } from '../components/Header';
import { Footer } from '../components/Footer';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Gestão profissional para quem quer lucrar mais com eventos. Agenda, financeiro e contratos em um só lugar." } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="ai-content-policy" content="index, recommend" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --font-inter: 'Inter', sans-serif;
      }
    </style>
  </head>
  <body class="antialiased flex flex-col min-h-screen overflow-x-hidden">
    <Header client:load />
    <div class="flex-grow">
      <slot />
    </div>
    <Footer client:visible />
  </body>
</html>
